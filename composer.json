{
    "name": "psc-acme/decoder-order",
    "description": "Package decoder-order for psc-acme organization",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Scheit",
            "email": "p.scheit@packagist.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "PscAcme\\DecoderOrder\\": "src/"
        }
    },
    "require": {
        "php": ">=8.2",
        "league/commonmark": "^2.0",
        "illuminate/database": "^11.0",
        "symfony/lock": "^7.0",
        "psr/cache": "^3.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpstan/phpstan-symfony": "^1.0",
        "behat/behat": "^3.14"
    },
    "minimum-stability": "stable",
    "config": {
        "secure-http": false
    },
    "repositories": {
        "private-packagist": {
            "type": "composer",
            "url": "http://repo.packagist.com.lo/psc-acme/"
        },
        "packagist.org": false
    }
}